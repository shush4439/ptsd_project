# Haven - Server Environment Configuration Template

# Server Port (Defaults to 8080)
PORT=8080

# Environment Mode ('development' | 'production')
NODE_ENV=development

# Session Signing Secret (Choose a strong random string)
SESSION_SECRET=your-secure-signed-session-secret-key-goes-here

# PostgreSQL Database Connection URL (e.g. from Render or Supabase)
# Leave empty to fall back to the in-memory database locally
DATABASE_URL=postgresql://username:password@localhost:5432/haven_db
